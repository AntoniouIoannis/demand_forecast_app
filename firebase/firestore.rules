rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow create: if request.auth.uid == userId;
      allow read: if request.auth.uid == userId;
      allow write: if request.auth.uid == userId;
      allow delete: if false;

      // Subcollections: upload-files, processing-files, received-files
      match /upload-files/{fileDoc} {
        allow read, write: if request.auth.uid == userId;
        allow delete: if false;
      }
      match /processing-files/{fileDoc} {
        allow read, write: if request.auth.uid == userId;
        allow delete: if false;
      }
      match /received-files/{fileDoc} {
        allow read, write: if request.auth.uid == userId;
        allow delete: if false;
      }
    }

    match /products/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /onhold_users/{uid} {
      allow create: if request.auth != null &&
        request.auth.uid == uid &&
        request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null &&
        request.auth.uid == uid &&
        request.resource.data.uid == resource.data.uid;
      allow delete: if false;
    }

    match /demo/{document} {
      allow create: if false;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /forecasts/{document} {
      allow get: if request.auth != null &&
        (resource == null || request.auth.uid == resource.data.userId);
      allow list: if request.auth != null;
      allow create, update, delete: if false;
    }

    // B2B/B2C Leads — each user reads/updates only their own leads.
    // Cloud Functions (admin SDK) write leads — no client create.
    match /leads/{leadId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.ownerUid;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.ownerUid &&
        request.resource.data.ownerUid == resource.data.ownerUid;
      allow create, delete: if false;
    }

    // Notifications — read-only for the owning user; written by Cloud Functions.
    match /notifications/{notifId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.ownerUid;
      allow create, update, delete: if false;
    }

    // Radar runs — read-only for the owning user; written by Cloud Functions.
    match /radar_runs/{runId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.ownerUid;
      allow create, update, delete: if false;
    }

  }
}
